# ============================================================
# .databricksignore — Filtro de Deploy para Databricks Apps
# ============================================================
# O `databricks sync` usa ESTE arquivo (se existir) ao invés do .gitignore.
# Tudo listado aqui NÃO será enviado para o Workspace remoto.
# IMPORTANTE: app.yaml NÃO está listado — ele DEVE ir para produção.
# ============================================================

# Git & Editor
.git/
.gitignore
.vscode/
.databricks/
.databricksignore

# Agent & AI Tooling (dev-only)
.agent/
AGENTS.md
README.md

# Test & Debug
.pytest_cache/
tests/
debug_*.py
debug_*.txt
diag*.py
diag*.txt
check_*.py
cleanup*.py
tmp_*
tmp/

# Data files (DB é criado em runtime via sync)
data/
*.parquet
*.duckdb
*.csv
*.xlsx
*.pdf
*.zip
Arquivos de contexto/
prod_logs.txt
export_data.py

# Python bytecode & env
__pycache__/
*.py[cod]
venv/

# Credenciais locais (produção usa Service Principal)
.env
.env*

# Outros
uploads/
assets/_icon_backups/
scripts/
